{
	"root": true,
	"extends": [
		"wikimedia/mediawiki/qunit"
	],
	"globals": {
		"sinon": "readonly"
	},
	"env": {
		"commonjs": true
	},
	"rules": {
		"no-jquery/no-global-selector": "off",
		"no-jquery/no-sizzle": "off",
		"es-x/no-resizable-and-growable-arraybuffers": "off",
		"no-jquery/no-class-state": "off",
		"no-jquery/no-done-fail": "warn"
	}
}
