{
	"name": "MultimediaViewer",
	"private": true,
	"scripts": {
		"build": "npm -s run minify",
		"lint": "grunt lint",
		"test": "grunt test",
		"minify": "npm -s run minify:svg",
		"minify:svg": "svgo --config=.svgo.config.js --quiet --recursive --folder resources/",
		"doc": "jsdoc -c jsdoc.json"
	},
	"devDependencies": {
		"eslint-config-wikimedia": "0.32.4",
		"grunt": "1.6.2",
		"grunt-banana-checker": "0.13.0",
		"grunt-eslint": "24.3.0",
		"grunt-stylelint": "0.21.0",
		"jsdoc-wmf-theme": "1.3.0",
		"stylelint-config-wikimedia": "0.19.3",
		"svgo": "3.3.3",
		"types-mediawiki": "^2.0.0"
	}
}
